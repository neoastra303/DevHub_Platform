# --- Django Settings ---
DJANGO_SETTINGS_MODULE=core.settings.dev
DJANGO_SECRET_KEY=your-super-secret-key-change-in-prod
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database Configuration ---
# For SQLite (default)
DJANGO_DB_ENGINE=django.db.backends.sqlite3
DJANGO_DB_NAME=db.sqlite3

# For PostgreSQL
# DJANGO_DB_ENGINE=django.db.backends.postgresql
# DJANGO_DB_NAME=devhub
# DJANGO_DB_USER=devhub_user
# DJANGO_DB_PASSWORD=devhub_pass
# DJANGO_DB_HOST=localhost
# DJANGO_DB_PORT=5432

# --- Security & Throttling ---
DEVHUB_API_WRITE_RATE=30/hour
DEVHUB_API_BURST_RATE=120/hour

# --- Timezone ---
DJANGO_TIME_ZONE=UTC
